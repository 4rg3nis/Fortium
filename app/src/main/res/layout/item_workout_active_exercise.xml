<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginTop="16dp"
    app:cardBackgroundColor="#2C2C2E"
    app:cardCornerRadius="16dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tvActiveExerciseName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Press de Banca" />

            <TextView
                android:id="@+id/btnRestTimerConfig"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_blue_translucent"
                android:drawableStart="@drawable/ic_timer"
                android:drawablePadding="6dp"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="@color/blue_400"
                android:textSize="13sp"
                android:textStyle="bold"
                app:drawableTint="@color/blue_400"
                tools:text="1:30" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/workoutActiveExcersice_tv_set"
                android:textColor="@color/white_alpha_60"
                android:textSize="12sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/workoutActiveExcersice_tv_anterior"
                android:textColor="@color/white_alpha_60"
                android:textSize="12sp" />

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/workoutActiveExcersice_tv_kg"
                android:textColor="@color/white_alpha_60"
                android:textSize="12sp" />

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:gravity="center"
                android:text="@string/workoutActiveExcersice_tv_reps"
                android:textColor="@color/white_alpha_60"
                android:textSize="12sp" />

            <TextView
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:gravity="center"
                android:text="@string/workoutActiveExcersice_tv_rpe"
                android:textColor="@color/white_alpha_60"
                android:textSize="12sp" />

            <View
                android:layout_width="48dp"
                android:layout_height="1dp"
                android:layout_marginStart="16dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutSetsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical" />

        <TextView
            android:id="@+id/btnAddSet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="@string/workoutActive_tv_add"
            android:textColor="@color/blue_400"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>